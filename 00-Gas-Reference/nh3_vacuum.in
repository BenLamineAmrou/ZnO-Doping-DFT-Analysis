&CONTROL
    calculation = 'relax'
    prefix = 'nh3_ref'
    outdir = './tmp/'
    pseudo_dir = '../pseudo/'
    forc_conv_thr = 1.0d-4
/
&SYSTEM
    ibrav = 1,           
    celldm(1) = 22.67,   
    nat = 4,             
    ntyp = 2,
    ecutwfc = 40.0,      
    ecutrho = 320.0,
/
&ELECTRONS
    conv_thr = 1.0d-8
    mixing_beta = 0.7
/
&IONS
    ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
 N  14.007  N.UPF
 H  1.008   H.UPF

ATOMIC_POSITIONS (angstrom)
N   6.00000   6.00000   6.00000
H   6.94000   6.00000   6.38000
H   5.53000   6.81400   6.38000
H   5.53000   5.18600   6.38000

K_POINTS (gamma)        
